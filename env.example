# Optional direct Nessus deb URL (skips Tenable API)
# NESSUS_DEB_URL=https://www.tenable.com/downloads/api/v2/pages/nessus/files/Nessus-10.11.2-debian10_amd64.deb

NESSUS_USERNAME=admin
NESSUS_PASSWORD=admin
NESSUS_UPDATE_URL=https://plugins.nessus.org/v2/nessus.php?f=all-2.0.tar.gz

# Auto-update plugins every N hours (optional)
NESSUS_AUTO_UPDATE_INTERVAL=24

# SSL certificate SAN (comma-separated); first entry is shown in the ready banner URL
# NESSUS_CERT_SAN=192.168.1.103,nessus.local

# Optional proxy for Tenable API, .deb download, plugins.nessus.org (omit = direct only from our side).
# NESSUS_PROXY=http://proxy.example.com:8080
# NESSUS_HTTP_PROXY=http://proxy.example.com:8080
# NESSUS_HTTPS_PROXY=http://proxy.example.com:8080
# NESSUS_ALL_PROXY=socks5h://127.0.0.1:1080
# NESSUS_NO_PROXY=localhost,127.0.0.1,::1,10.0.0.0/8
